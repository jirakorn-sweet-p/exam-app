# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง

# Connection string จาก Neon (กดปุ่ม Connect ใน Neon dashboard)
# รูปแบบ: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_85SynCgNBUPI@ep-falling-queen-aoa54pd7-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# คีย์ลับสำหรับเซ็น JWT (สุ่มให้ยาวและเดายาก)
JWT_SECRET=replace-with-a-long-random-secret

# รหัสผ่านบัญชีผู้ดูแลระบบ (admin) ที่ระบบจะสร้างให้ครั้งแรก
ADMIN_PASSWORD=admin123

# ตั้งเป็น production เมื่อ deploy จริง
NODE_ENV=development

# พอร์ต (local). Render จะกำหนดให้เองอัตโนมัติ
PORT=3000

# ตั้ง false ถ้าใช้ Postgres local ที่ไม่มี SSL
PGSSL=true
